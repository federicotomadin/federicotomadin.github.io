# Optional: Web3Forms access key for contact form delivery
# VITE_WEB3FORMS_ACCESS_KEY=your_key_here
#
# For production (GitHub Actions), add the same key as a repository secret:
# Settings → Secrets and variables → Actions → New repository secret
# Name: VITE_WEB3FORMS_ACCESS_KEY

# Optional: override CV download URL (defaults to /cv/federico-tomadin-cv.pdf)
# Google Drive direct download example:
# VITE_CV_URL=https://drive.google.com/uc?export=download&id=YOUR_FILE_ID
